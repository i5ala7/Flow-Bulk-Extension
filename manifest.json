{
  "manifest_version": 3,
  "name": "Flow Bulk Generator",
  "version": "2.1",
  "description": "Bulk image generation for Google Flow",
  "permissions": ["activeTab", "scripting", "downloads", "sidePanel", "storage"],
  "host_permissions": ["https://labs.google/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Flow Bulk Generator"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/fx/tools/flow*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
